 // restart it upon new changes in the /build folder.\n  const restart = require('restart');\n  const build = require('./scripts/build');\n  build({\n    watch: true,\n    onComplete: () => {\n      restart({ entry: './build/app' });\n    },\n  });\n}\n```\n\n```bash\n$ node ./server\n```\n\n## License\n\nCopyright (c) 2018-present Kriasoft | MIT License\n","maintainers":[{"email":"hello@tarkus.me","name":"koistya"},{"email":"olav@comoyo.com","name":"olavhn"}],"time":{"modified":"2022-06-26T12:05:20.604Z","created":"2013-08-30T11:28:22.950Z","0.0.0":"2013-08-30T11:28:25.725Z","0.0.1":"2013-09-02T06:40:21.481Z","0.0.2":"2014-03-16T09:39:50.468Z","0.0.3":"2014-03-16T10:20:27.887Z","0.0.4":"2014-03-17T09:38:50.721Z","0.1.0":"2018-04-16T11:15:29.644Z","1.0.0-beta.1":"2018-08-28T20:47:10.425Z","1.0.0-beta.2":"2018-08-28T21:43:48.935Z","1.0.0":"2018-08-29T08:08:02.227Z","1.1.0":"2018-08-31T04:00:43.536Z","1.2.0":"2018-08-31T04:19:53.225Z","2.0.0":"2018-08-31T18:51:27.205Z"},"author":{"name":"Kriasoft","email":"hello@kriasoft.com"},"repository":{"type":"git","url":"git+https://github.com/kriasoft/restart.git"},"keywords":["monitor","development","restart","autoload","reload","terminal"],"bugs":{"url":"https://github.com/kriasoft/restart/issues"},"license":"MIT","readmeFilename":"README.md","homepage":"https://github.com/kriasoft/restart#readme"}